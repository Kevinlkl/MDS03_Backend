    "        autoencoder=autoencoder,\n",
    "        unet=ema_unet,\n",
    "        scheduler=noise_scheduler,\n",
    "        scale_factor=float(globals().get(\"scale_factor_runtime\", scale_factor)),\n",
    "        device=device,\n",
    "        latent_spatial_shape=z_shape,\n",
    "        batch_size=1,\n",
    "        latent_channels=latent_channels,\n",
    "        num_inference_steps=INFERENCE_STEPS,\n",
    "    )\n",
    "    synth_vol = pred_t1[0, 0].detach().cpu().numpy()\n",
    "\n",
    "# Normalize and align shapes for side-by-side visualization\n",
    "real_n = _normalize_01(real_vol)\n",
    "synth_n = _normalize_01(synth_vol)\n",
    "synth_n = _resize_to_match(synth_n, real_n.shape)\n",
    "\n",
    "mid_x = real_n.shape[0] // 2\n",
    "mid_y = real_n.shape[1] // 2\n",
    "mid_z = real_n.shape[2] // 2\n",
    "\n",
    "views = [\n",
    "    (\"Axial (mid Z)\", lambda v: v[:, :, mid_z]),\n",
    "    (\"Coronal (mid Y)\", lambda v: v[:, mid_y, :]),\n",
    "    (\"Sagittal (mid X)\", lambda v: v[mid_x, :, :]),\n",
    "]\n",
    "\n",
    "fig, axes = plt.subplots(3, 3, figsize=(12, 12))\n",
    "for r, (title, slicer) in enumerate(views):\n",
    "    real_slice = slicer(real_n)\n",
    "    synth_slice = slicer(synth_n)\n",
    "    diff_slice = np.abs(real_slice - synth_slice)\n",
    "\n",
    "    axes[r, 0].imshow(real_slice, cmap=\"gray\")\n",
    "    axes[r, 0].set_title(f\"Real - {title}\")\n",
    "    axes[r, 0].axis(\"off\")\n",
    "\n",
    "    axes[r, 1].imshow(synth_slice, cmap=\"gray\")\n",
    "    axes[r, 1].set_title(f\"Synthetic - {title}\")\n",
    "    axes[r, 1].axis(\"off\")\n",
    "\n",
    "    im = axes[r, 2].imshow(diff_slice, cmap=\"magma\")\n",
    "    axes[r, 2].set_title(f\"Abs Diff - {title}\")\n",
    "    axes[r, 2].axis(\"off\")\n",
    "    fig.colorbar(im, ax=axes[r, 2], fraction=0.046, pad=0.04)\n",
    "\n",
    "plt.suptitle(\"One-sample comparison: real vs synthetic T1\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"Real volume path     :\", real_path)\n",
    "print(\"Synthetic volume path:\", synth_path if synth_path.exists() else \"Generated in-memory (not yet saved)\")\n",
    "print(\"Compared shape       :\", real_n.shape)\n",
    "print(\"Mean absolute diff   :\", float(np.mean(np.abs(real_n - synth_n))))"
   ]
