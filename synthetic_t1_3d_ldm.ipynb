    "# Install once in the CURRENT notebook kernel, then restart kernel and run all.\n",
    "# In Jupyter/VS Code, prefer %pip (not !pip).\n",
    "%pip install monai monai-generative nibabel scikit-image tqdm matplotlib\n",
    "\n",
