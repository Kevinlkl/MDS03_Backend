cation/vnd.jupyter.widget-view+json":{"model_id":"b98a2ebaaa18461fa77d1cadd9946c3f","version_major":2,"version_minor":0},"text/plain":["Diff Train:   0%|                                                                               | 0/345 [00:00…"]},"metadata":{},"output_type":"display_data"},{"data":{"application/vnd.jupyter.widget-view+json":{"model_id":"f4191d329585471c97841a5b6fde3d0d","version_major":2,"version_minor":0},"text/plain":["Diff Val:   0%|                                                                                  | 0/98 [00:00…"]},"metadata":{},"output_type":"display_data"},{"name":"stdout","output_type":"stream","text":["Diff Epoch 100/100 | train=0.352880 | val_noise_mse=0.439622 | lr=8.00e-06\n"]},{"name":"stderr","output_type":"stream","text":["/tmp/ipykernel_492/377145992.py:26: FutureWarning: `torch.cuda.amp.autocast(args...)` is deprecated. Please use `torch.amp.autocast('cuda', args...)` instead.\n","  with autocast(enabled=use_amp):\n"]},{"name":"stdout","output_type":"stream","text":["Saved synthetic sample: /content/drive/MyDrive/MDS03_Backend_outputs/synthetic_t1_3d_ldm/generated/sample_synth_t1.nii.gz\n"]},{"name":"stderr","output_type":"stream","text":["/tmp/ipykernel_492/377145992.py:26: FutureWarning: `torch.cuda.amp.autocast(args...)` is deprecated. Please use `torch.amp.autocast('cuda', args...)` instead.\n","  with autocast(enabled=use_amp):\n"]},{"name":"stdout","output_type":"stream","text":["Eval case 1/8 | PSNR=10.789 | SSIM=0.0813\n","Eval case 2/8 | PSNR=10.311 | SSIM=0.0942\n","Eval case 3/8 | PSNR=10.947 | SSIM=0.0837\n","Eval case 4/8 | PSNR=10.307 | SSIM=0.0722\n","Eval case 5/8 | PSNR=11.504 | SSIM=0.0943\n","Eval case 6/8 | PSNR=8.508 | SSIM=0.0397\n","Eval case 7/8 | PSNR=9.114 | SSIM=0.0610\n","Eval case 8/8 | PSNR=10.573 | SSIM=0.0984\n","===== Diffusion Evaluation (against matched validation volumes) =====\n","Mean PSNR: 10.257\n","Mean SSIM: 0.0781\n","Note: for unconditional generation, this is only a rough proxy metric.\n","Saved consolidated trained model: /content/drive/MyDrive/MDS03_Backend_outputs/synthetic_t1_3d_ldm/trained_model/synthetic_t1_ldm_trained_model.pth\n"]}],"source":["# =========================\n","# Run control\n","# =========================\n","# Adaptive execution policy:\n","RUN_AE_TRAIN = (device.type == \"cuda\") or (globals().get(\"CPU_FAST_MODE\", False) and AE_EPOCHS \u003e 0)\n","RUN_DIFF_TRAIN = device.type == \"cuda\"  # diffusion training on CPU is usually impractical\n","RUN_SAMPLE = device.type == \"cuda\"  # sampling is also heavy on CPU\n","RUN_DIFF_PSNR_SSIM_EVAL = device.type == \"cuda\"\n","DIFF_EVAL_CASES = 1 if device.type != \"cuda\" else 8\n","\n","if device.type != \"cuda\":\n","    if RUN_AE_TRAIN:\n","        print(\"CUDA unavailable/insufficient. Running CPU fast-mode AE training only.\")\n","        print(\"Diffusion training/sampling/eval remain disabled in CPU mode.\")\n","    else:\n","        print(\"CUDA unavailable and CPU fast-mode disabled. Training is skipped.\")\n","\n","scale_factor_runtime = float(scale_factor)\n","\n","# Save structure in Drive-style organization:\n","# checkpoints/autoencoder, checkpoints/diffusion, trained_model\n","ckpt_root = OUTPUT_ROOT / \"checkpoints\"\n","ae_ckpt_dir = ckpt_root / \"autoencoder\"\n","diff_ckpt_dir = ckpt_root / \"diffusion\"\n","trained_model_dir = OUTPUT_ROOT / \"trained_model\"\n","generated_dir = OUTPUT_ROOT / \"generated\"\n","\n","for d in [ae_ckpt_dir, diff_ckpt_dir, trained_model_dir, generated_dir]:\n","    d.mkdir(parents=True, exist_ok=True)  # auto-create output folders if missing\n","\n","ae_latest_path = ae_ckpt_dir / \"autoencoder_latest.pth\"\n","ae_best_path = ae_ckpt_dir / \"autoencoder_best.pth\"\n","diff_latest_path = diff_ckpt_dir / \"latent_diffusion_latest.pth\"\n","diff_best_path = diff_ckpt_dir / \"latent_diffusion_best.pth\"\n","trained_model_path = trained_model_dir / \"synthetic_t1_ldm_trained_model.pth\"\n","\n","# -------------------------\n","# 1) Autoencoder training\n","# -------------------------\n","best_ae_val = float(\"inf\")\n","if ae_best_path.exists():\n","    ae_ckpt = torch.load(ae_best_path, map_location=device)\n","    if \"autoencoder_state_dict\" in ae_ckpt:\n","        autoencoder.load_state_dict(ae_ckpt[\"autoencoder_state_dict\"])\n","        best_ae_val = ae_ckpt.get(\"best_val_loss\", best_ae_val)\n","    print(f\"Loaded AE checkpoint: {ae_best_path}\")\n","\n","if RUN_AE_TRAIN:\n","    for epoch in range(AE_EPOCHS):\n","        tr = train_autoencoder_epoch(autoencoder, train_loader, optimizer_ae, scaler_ae, device)\n","        va = validate_autoencoder_epoch(autoencoder, val_loader, device)\n","        print(\n","            f\"AE Epoch {epoch + 1}/{AE_EPOCHS} | train_loss={tr:.6f} | val_loss={va['loss']:.6f} | val_psnr={va['psnr']:.3f} | val_ssim={va['ssim']:.4f}\"\n","        )\n","\n","        ae_state = {\n","            \"epoch\": epoch + 1,\n","            \"autoencoder_state_dict\": autoencoder.state_dict(),\n","            \"optimizer_state_dict\": optimizer_ae.state_dict(),\n","            \"best_val_loss\": best_ae_val,\n","            \"last_val_psnr\": va[\"psnr\"],\n","            \"last_val_ssim\": va[\"ssim\"],\n","            \"config\": {\n","                \"target_shape\": TARGET_SHAPE,\n","                \"target_pixdim\": TARGET_PIXDIM,\n","            },\n","        }\n","        torch.save(ae_state, ae_latest_path)\n","\n","        if va[\"loss\"] \u003c best_ae_val:\n","            best_ae_val = va[\"loss\"]\n","            ae_state[\"best_val_loss\"] = best_ae_val\n","            torch.save(ae_state, ae_best_path)\n","            print(f\"Saved new best AE checkpoint (val_loss={best_ae_val:.6f})\")\n","\n","# Always load best AE before diffusion\n","if ae_best_path.exists():\n","    ae_ckpt = torch.load(ae_best_path, map_location=device)\n","    autoencoder.load_state_dict(ae_ckpt[\"autoencoder_state_dict\"])\n","autoencoder.eval()\n","for p in autoencoder.parameters():\n","    p.requires_grad = False\n","\n","# -------------------------\n","# 2) Diffusion training\n","# -------------------------\n","best_diff_val = float(\"inf\")\n","if diff_best_path.exists():\n","    d_ckpt = torch.load(diff_best_path, map_location=device)\n","    if \"unet_state_dict\" in d_ckpt:\n","        unet.load_state_dict(d_ckpt[\"unet_state_dict\"])\n","    if \"ema_unet_state_dict\" in d_ckpt:\n","        ema_unet.load_state_dict(d_ckpt[\"ema_unet_state_dict\"])\n","    scale_factor_runtime = float(d_ckpt.get(\"scale_factor\", scale_factor_runtime))\n","    best_diff_val = d_ckpt.get(\"best_val_loss\", best_diff_val)\n","    print(f\"Loaded diffusion checkpoint: {diff_best_path}\")\n","    print(f\"Restored scale_factor={scale_factor_runtime:.6f}\")\n","\n","if RUN_DIFF_TRAIN:\n","    scale_factor_runtime = float(estimate_scale_factor(autoencoder, train_loader, device))\n","    print(f\"Estimated scale_factor={scale_factor_runtime:.6f}\")\n","\n","    for epoch in range(DIFF_EPOCHS):\n","        tr = train_diffusion_epoch(\n","            autoencoder=autoencoder,\n","            unet=unet,\n","            ema_unet=ema_unet,\n","            noise_scheduler=noise_scheduler,\n","            loader=train_loader,\n","            optimizer=optimizer_diff,\n","            scaler=scaler_diff,\n","            device=device,\n","            scale_factor=scale_factor_runtime,\n","            grad_accum_steps=GRAD_ACCUM_STEPS,\n","            ema_decay=EMA_DECAY,\n","            offset_noise=OFFSET_NOISE,\n","        )\n","\n","        va = validate_diffusion_epoch(\n","            autoencoder=autoencoder,\n","            eval_unet=ema_unet,\n","            noise_scheduler=noise_scheduler,\n","            loader=val_loader,\n","            device=device,\n","            scale_factor=scale_factor_runtime,\n","            seed=1234 + epoch,\n","        )\n","\n","        lr_scheduler_diff.step()\n","        print(\n","            f\"Diff Epoch {epoch + 1}/{DIFF_EPOCHS} | train={tr:.6f} | val_noise_mse={va:.6f} | lr={optimizer_diff.param_groups[0]['lr']:.2e}\"\n","        )\n","\n","        d_state = {\n","            \"epoch\": epoch + 1,\n","            \"unet_state_dict\": unet.state_dict(),\n","            \"ema_unet_state_dict\": ema_unet.state_dict(),\n","            \"optimizer_state_dict\": optimizer_diff.state_dict(),\n","            \"scaler_state_dict\": scaler_diff.state_dict(),\n","            \"best_val_loss\": best_diff_val,\n","            \"scale_factor\": scale_factor_runtime,\n","            \"latent_channels\": latent_channels,\n","            \"config\": {\n","                \"target_shape\": TARGET_SHAPE,\n","                \"target_pixdim\": TARGET_PIXDIM,\n","                \"num_diffusion_timesteps\": NUM_DIFFUSION_TIMESTEPS,\n","            },\n","        }\n","        torch.save(d_state, diff_latest_path)\n","\n","        if va \u003c best_diff_val:\n","            best_diff_val = va\n","            d_state[\"best_val_loss\"] = best_diff_val\n","            torch.save(d_state, diff_best_path)\n","            print(f\"Saved new best diffusion checkpoint (val_noise_mse={best_diff_val:.6f})\")\n","\n","        if (epoch + 1) % SAVE_EVERY == 0:\n","            torch.save(d_state, diff_ckpt_dir / f\"latent_diffusion_epoch_{epoch + 1:04d}.pth\")\n","\n","# -------------------------\n","# 3) Sampling\n","# -------------------------\n","if RUN_SAMPLE:\n","    if diff_best_path.exists():\n","        d_ckpt = torch.load(diff_best_path, map_location=device)\n","        if \"unet_state_dict\" in d_ckpt:\n","            unet.load_state_dict(d_ckpt[\"unet_state_dict\"])\n","        if \"ema_unet_state_dict\" in d_ckpt:\n","            ema_unet.load_state_dict(d_ckpt[\"ema_unet_state_dict\"])\n","        scale_factor_runtime = float(d_ckpt.get(\"scale_factor\", scale_factor_runtime))\n","    else:\n","        print(\"Warning: diffusion best checkpoint not found, sampling with current in-memory weights.\")\n","\n","    sample_batch = next(iter(val_loader))\n","    sample_real = sample_batch[\"image\"].to(device)\n","    with torch.no_grad():\n","        z_shape = autoencoder.encode_stage_2_inputs(sample_real[:1]).shape[2:]\n","\n","    pred_t1 = generate_t1(\n","        autoencoder=autoencoder,\n","        unet=ema_unet,\n","        scheduler=noise_scheduler,\n","        scale_factor=scale_factor_runtime,\n","        device=device,\n","        latent_spatial_shape=z_shape,\n","        batch_size=1,\n","        latent_channels=latent_channels,\n","        num_inference_steps=INFERENCE_STEPS,\n","    )\n","\n","    pred_path = generated_dir / \"sample_synth_t1.nii.gz\"\n","    ref_path = val_files[0][\"image\"] if len(val_files) \u003e 0 else None\n","    save_nifti_volume(pred_t1[0], pred_path, reference_nifti_path=ref_path)\n","    print(f\"Saved synthetic sample: {pred_path}\")\n","\n","# -------------------------\n","# 4) Diffusion PSNR/SSIM evaluation (optional)\n","# -------------------------\n","if RUN_DIFF_PSNR_SSIM_EVAL:\n","    if diff_best_path.exists():\n","        d_ckpt = torch.load(diff_best_path, map_location=device)\n","        if \"ema_unet_state_dict\" in d_ckpt:\n","            ema_unet.load_state_dict(d_ckpt[\"ema_unet_state_dict\"])\n","        scale_factor_runtime = float(d_ckpt.get(\"scale_factor\", scale_factor_runtime))\n","\n","    max_cases = min(DIFF_EVAL_CASES, len(val_loader))\n","    psnr_vals = []\n","    ssim_vals = []\n","\n","    for i, batch in enumerate(val_loader):\n","        if i \u003e= max_cases:\n","            break\n","        real_t1 = batch[\"image\"].to(device)\n","        with torch.no_grad():\n","            z_shape = autoencoder.encode_stage_2_inputs(real_t1[:1]).shape[2:]\n","\n","        fake_t1 = generate_t1(\n","            autoencoder=autoencoder,\n","            unet=ema_unet,\n","            scheduler=noise_scheduler,\n","            scale_factor=scale_factor_runtime,\n","            device=device,\n","            latent_spatial_shape=z_shape,\n","            batch_size=1,\n","            latent_channels=latent_channels,\n","            num_inference_steps=INFERENCE_STEPS,\n","        )\n","\n","        gt_np = real_t1[0, 0].detach().cpu().numpy()\n","        pred_np = fake_t1[0, 0].detach().cpu().numpy()\n","        p_val, s_val = _volume_psnr_ssim(gt_np, pred_np)\n","        psnr_vals.append(p_val)\n","        ssim_vals.append(s_val)\n","        print(f\"Eval case {i+1}/{max_cases} | PSNR={p_val:.3f} | SSIM={s_val:.4f}\")\n","\n","    if psnr_vals:\n","        print(\"===== Diffusion Evaluation (against matched validation volumes) =====\")\n","        print(f\"Mean PSNR: {np.mean(psnr_vals):.3f}\")\n","        print(f\"Mean SSIM: {np.mean(ssim_vals):.4f}\")\n","        print(\"Note: for unconditional generation, this is only a rough proxy metric.\")\n","\n","# -------------------------\n","# 5) Consolidated trained-model file\n","# -------------------------\n","trained_model_payload = {\n","    \"autoencoder_state_dict\": autoencoder.state_dict(),\n","    \"unet_state_dict\": unet.state_dict(),\n","    \"ema_unet_state_dict\": ema_unet.state_dict(),\n","    \"scale_factor\": float(scale_factor_runtime),\n","    \"latent_channels\": int(latent_channels),\n","    \"paths\": {\n","        \"ae_best\": str(ae_best_path),\n","        \"ae_latest\": str(ae_latest_path),\n","        \"diff_best\": str(diff_best_path),\n","        \"diff_latest\": str(diff_latest_path),\n","    },\n","    \"config\": {\n","        \"target_shape\": TARGET_SHAPE,\n","        \"target_pixdim\": TARGET_PIXDIM,\n","        \"num_diffusion_timesteps\": NUM_DIFFUSION_TIMESTEPS,\n","        \"inference_steps\": INFERENCE_STEPS,\n","    },\n","}\n","torch.save(trained_model_payload, trained_model_path)\n","print(f\"Saved consolidated trained model: {trained_model_path}\")"]},{"cell_type":"code","execution_count":null,"id":"0f49d4cf","metadata":{"colab":{"background_save":true},"id":"0f49d4cf"},"outputs":[{"data":{"image/png":"\n","text/plain":["\u003cFigure size 1200x1200 with 12 Axes\u003e"]},"metadata":{},"output_type":"display_data"},{"name":"stdout","output_type":"stream","text":["Real volume path     : /content/extracted_datasets/final-clean-data/T1/BraTS20_Training_253_t1.nii\n","Synthetic volume path: /content/drive/MyDrive/MDS03_Backend_outputs/synthetic_t1_3d_ldm/generated/sample_synth_t1.nii.gz\n","Compared shape       : (240, 240, 155)\n","Mean absolute diff   : 0.6323339939117432\n"]}],"source":["# =========================\n","# One-sample real vs synthetic comparison (middle slices + difference maps)\n","# =========================\n","import matplotlib.pyplot as plt\n","from pathlib import Path\n","import numpy as np\n","import nibabel as nib\n","\n","def _load_nifti_volume(path: Path) -\u003e np.ndarray:\n","    vol = nib.load(str(path)).get_fdata().astype(np.float32)\n","    if vol.ndim != 3:\n","        raise ValueError(f\"Expected 3D volume, got shape {vol.shape} for {path}\")\n","    return vol\n","\n","def _normalize_01(vol: np.ndarray) -\u003e np.ndarray:\n","    vmin = np.percentile(vol, 0.5)\n","    vmax = np.percentile(vol, 99.5)\n","    vol = np.clip(vol, vmin, vmax)\n","    return (vol - vol.min()) / (vol.max() - vol.min() + 1e-8)\n","\n","def _resize_to_match(src: np.ndarray, target_shape: tuple[int, int, int]) -\u003e np.ndarray:\n","    if src.shape == target_shape:\n","        return src\n","    src_t = torch.from_numpy(src).unsqueeze(0).unsqueeze(0).float()\n","    out = F.interpolate(src_t, size=target_shape, mode=\"trilinear\", align_corners=False)\n","    return out.squeeze(0).squeeze(0).cpu().numpy()\n","\n","# Pick one real validation sample (first case)\n","if len(val_files) == 0:\n","    raise RuntimeError(\"val_files is empty. Run data preparation cells first.\")\n","real_path = Path(val_files[0][\"image\"])\n","real_vol = _load_nifti_volume(real_path)\n","\n","# Use saved synthetic sample if available; otherwise generate one now\n","synth_path = OUTPUT_ROOT / \"generated\" / \"sample_synth_t1.nii.gz\"\n","if synth_path.exists():\n","    synth_vol = _load_nifti_volume(synth_path)\n","else:\n","    if not (\"autoencoder\" in globals() and \"ema_unet\" in globals() and \"noise_scheduler\" in globals()):\n","        raise RuntimeError(\"Model objects not found. Run training/sampling cell first.\")\n","\n","    with torch.no_grad():\n","        real_t = torch.from_numpy(real_vol).unsqueeze(0).unsqueeze(0).to(device=device, dtype=torch.float32)\n","        real_t = F.interpolate(real_t, size=TARGET_SHAPE, mode=\"trilinear\", align_corners=False)\n","        z_shape = autoencoder.encode_stage_2_inputs(real_t).shape[2:]\n","\n","    pred_t1 = generate_t1(\n","        autoencoder=autoencoder,\n","        unet=ema_unet,\n","        scheduler=noise_scheduler,\n","        scale_factor=float(globals().get(\"scale_factor_runtime\", scale_factor)),\n","        device=device,\n","        latent_spatial_shape=z_shape,\n","        batch_size=1,\n","        latent_channels=latent_channels,\n","        num_inference_steps=INFERENCE_STEPS,\n","    )\n","    synth_vol = pred_t1[0, 0].detach().cpu().numpy()\n","\n","# Normalize and align shapes for side-by-side visualization\n","real_n = _normalize_01(real_vol)\n","synth_n = _normalize_01(synth_vol)\n","synth_n = _resize_to_match(synth_n, real_n.shape)\n","\n","mid_x = real_n.shape[0] // 2\n","mid_y = real_n.shape[1] // 2\n","mid_z = real_n.shape[2] // 2\n","\n","views = [\n","    (\"Axial (mid Z)\", lambda v: v[:, :, mid_z]),\n","    (\"Coronal (mid Y)\", lambda v: v[:, mid_y, :]),\n","    (\"Sagittal (mid X)\", lambda v: v[mid_x, :, :]),\n","]\n","\n","fig, axes = plt.subplots(3, 3, figsize=(12, 12))\n","for r, (title, slicer) in enumerate(views):\n","    real_slice = slicer(real_n)\n","    synth_slice = slicer(synth_n)\n","    diff_slice = np.abs(real_slice - synth_slice)\n","\n","    axes[r, 0].imshow(real_slice, cmap=\"gray\")\n","    axes[r, 0].set_title(f\"Real - {title}\")\n","    axes[r, 0].axis(\"off\")\n","\n","    axes[r, 1].imshow(synth_slice, cmap=\"gray\")\n","    axes[r, 1].set_title(f\"Synthetic - {title}\")\n","    axes[r, 1].axis(\"off\")\n","\n","    im = axes[r, 2].imshow(diff_slice, cmap=\"magma\")\n","    axes[r, 2].set_title(f\"Abs Diff - {title}\")\n","    axes[r, 2].axis(\"off\")\n","    fig.colorbar(im, ax=axes[r, 2], fraction=0.046, pad=0.04)\n","\n","plt.suptitle(\"One-sample comparison: real vs synthetic T1\")\n","plt.tight_layout()\n","plt.show()\n","\n","print(\"Real volume path     :\", real_path)\n","print(\"Synthetic volume path:\", synth_path if synth_path.exists() else \"Generated in-memory (not yet saved)\")\n","print(\"Compared shape       :\", real_n.shape)\n","print(\"Mean absolute diff   :\", float(np.mean(np.abs(real_n - synth_n))))"]},{"cell_type":"code","execution_count":null,"id":"48755753","metadata":{"colab":{"background_save":true},"id":"48755753"},"outputs":[{"name":"stdout","output_type":"stream","text":["Remounting Google Drive for export...\n","Mounted at /content/drive\n","Created archive: /content/MDS03_Backend_synthetic_t1_3d_ldm_artifacts_20260328_001241.zip\n","Copied archive to Drive: /content/drive/MyDrive/T1_Synthetic_Model/MDS03_Backend_synthetic_t1_3d_ldm_artifacts_20260328_001241.zip\n","Saved paths summary:\n"," - AE checkpoints dir      : /content/drive/MyDrive/MDS03_Backend_outputs/synthetic_t1_3d_ldm/checkpoints/autoencoder\n"," - Diffusion checkpoints dir: /content/drive/MyDrive/MDS03_Backend_outputs/synthetic_t1_3d_ldm/checkpoints/diffusion\n"," - Trained model dir       : /content/drive/MyDrive/MDS03_Backend_outputs/synthetic_t1_3d_ldm/trained_model\n"," - Generated samples dir   : /content/drive/MyDrive/MDS03_Backend_outputs/synthetic_t1_3d_ldm/generated\n","Triggering browser download ...\n"]},{"data":{"application/javascript":["\n","    async function download(id, filename, size) {\n","      if (!google.colab.kernel.accessAllowed