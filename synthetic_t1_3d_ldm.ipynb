    "# =========================\n",
    "# One-sample real vs synthetic comparison (middle slices + difference maps)\n",
    "# =========================\n",
    "import matplotlib.pyplot as plt\n",
    "from pathlib import Path\n",
    "import numpy as np\n",
    "import nibabel as nib\n",
    "\n",
    "def _load_nifti_volume(path: Path) -> np.ndarray:\n",
    "    vol = nib.load(str(path)).get_fdata().astype(np.float32)\n",
    "    if vol.ndim != 3:\n",
    "        raise ValueError(f\"Expected 3D volume, got shape {vol.shape} for {path}\")\n",
    "    return vol\n",
    "\n",
    "def _normalize_01(vol: np.ndarray) -> np.ndarray:\n",
    "    vmin = np.percentile(vol, 0.5)\n",
    "    vmax = np.percentile(vol, 99.5)\n",
    "    vol = np.clip(vol, vmin, vmax)\n",
    "    return (vol - vol.min()) / (vol.max() - vol.min() + 1e-8)\n",
    "\n",
    "def _resize_to_match(src: np.ndarray, target_shape: tuple[int, int, int]) -> np.ndarray:\n",
    "    if src.shape == target_shape:\n",
    "        return src\n",
    "    src_t = torch.from_numpy(src).unsqueeze(0).unsqueeze(0).float()\n",
    "    out = F.interpolate(src_t, size=target_shape, mode=\"trilinear\", align_corners=False)\n",
    "    return out.squeeze(0).squeeze(0).cpu().numpy()\n",
    "\n",
    "# Pick one real validation sample (first case)\n",
