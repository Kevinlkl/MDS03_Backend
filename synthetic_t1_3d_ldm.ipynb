ime\n","from pathlib import Path\n","\n","EXPORT_BASENAME = \"MDS03_Backend_synthetic_t1_3d_ldm_artifacts\"\n","EXPORT_LOCAL_DIR = Path(\"/content\")\n","EXPORT_DRIVE_DIR = Path(\"/content/drive/MyDrive/T1_Synthetic_Model\")\n","TRIGGER_BROWSER_DOWNLOAD = True\n","COPY_ARCHIVE_TO_DRIVE = True\n","FORCE_REMOUNT_DRIVE_FOR_EXPORT = True\n","\n","runtime_output_root = OUTPUT_ROOT if \"OUTPUT_ROOT\" in globals() else Path(\"/content/drive/MyDrive/MDS03_Backend_outputs/synthetic_t1_3d_ldm\")\n","\n","# New organized layout\n","runtime_ae_dir = runtime_output_root / \"checkpoints\" / \"autoencoder\"\n","runtime_diff_dir = runtime_output_root / \"checkpoints\" / \"diffusion\"\n","runtime_trained_model_dir = runtime_output_root / \"trained_model\"\n","runtime_generated_dir = runtime_output_root / \"generated\"\n","\n","if COPY_ARCHIVE_TO_DRIVE:\n","    try:\n","        from google.colab import drive\n","        if FORCE_REMOUNT_DRIVE_FOR_EXPORT:\n","            print(\"Remounting Google Drive for export...\")\n","            drive.mount(\"/content/drive\", force_remount=True)\n","        elif not Path(\"/content/drive/MyDrive\").exists():\n","            print(\"Mounting Google Drive for export...\")\n","            drive.mount(\"/content/drive\")\n","    except Exception as e:\n","        print(f\"Drive mount/remount step skipped or failed: {e}\")\n","\n","ts = datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n","EXPORT_LOCAL_DIR.mkdir(parents=True, exist_ok=True)\n","EXPORT_DRIVE_DIR.mkdir(parents=True, exist_ok=True)\n","\n","artifact_files = []\n","\n","def _collect_if_exists(path: Path):\n","    if path.exists():\n","        artifact_files.append(path)\n","\n","# AE checkpoints\n","_collect_if_exists(runtime_ae_dir / \"autoencoder_best.pth\")\n","_collect_if_exists(runtime_ae_dir / \"autoencoder_latest.pth\")\n","\n","# Diffusion checkpoints\n","_collect_if_exists(runtime_diff_dir / \"latent_diffusion_best.pth\")\n","_collect_if_exists(runtime_diff_dir / \"latent_diffusion_la