# Copy this file to .env and update with your local paths
# .env is in .gitignore and will NOT be committed to Git

# ===== Model Storage Paths =====
# These should point to your local directories where model weights are stored

# Main models directory (where you'll organize all model files)
MODELS_DIR=./models

# Generated outputs directory
OUTPUTS_DIR=./outputs

# Latent Diffusion 3D Model directory
# Expected structure:
#   models/synthetic_t1_3d_ldm/
#   ├── checkpoints/
#   │   ├── autoencoder_best.pth (1 GB)
#   │   ├── latent_diffusion_best.pth (400 MB)
#   │   └── ...
LATENT_DIFFUSION_DIR=./models/synthetic_t1_3d_ldm

# Stable Diffusion LoRA directory
# Expected structure:
#   models/sd_t1_mri/
#   ├── lora/
#   │   ├── pytorch_lora_weights.safetensors
#   │   └── ...
SD_LORA_DIR=./models/sd_t1_mri

# Specific checkpoint paths (overrides defaults)
AE_CHECKPOINT=./models/synthetic_t1_3d_ldm/checkpoints/autoencoder_best.pth
DIFFUSION_CHECKPOINT=./models/synthetic_t1_3d_ldm/checkpoints/latent_diffusion_best.pth
SD_LORA_CHECKPOINT=./models/sd_t1_mri/lora

# ===== Runtime Configuration =====

# Device: "cuda" or "cpu"
DEVICE=cuda

# Use automatic mixed precision (AMP) for faster inference
USE_AMP=true

# Model input shape (H, W, D)
TARGET_SHAPE=96,96,64

# Batch size for inference
BATCH_SIZE=1

# Number of dataloader workers
NUM_WORKERS=0
