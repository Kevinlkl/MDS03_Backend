    "# Quick dataset path diagnostic for final-clean-data.zip layout\n",
    "from pathlib import Path\n",
    "import os\n",
    "\n",
    "def _find_t1_roots(search_roots, max_depth=7, max_dirs=50000, max_hits=20):\n",
    "    hits = []\n",
    "    for root in search_roots:\n",
    "        root = Path(root).expanduser()\n",
    "        if not root.exists() or not root.is_dir():\n",
    "            continue\n",
    "        base_depth = len(root.parts)\n",
    "        scanned = 0\n",
    "        for dirpath, dirnames, _ in os.walk(root):\n",
    "            scanned += 1\n",
    "            if scanned > max_dirs:\n",
    "                break\n",
    "            cur = Path(dirpath)\n",
    "            depth = len(cur.parts) - base_depth\n",
    "            if depth > max_depth:\n",
    "                dirnames[:] = []\n",
    "                continue\n",
    "\n",
    "            if \"T1\" in dirnames:\n",
    "                t1_dir = (cur / \"T1\").resolve()\n",
    "                hits.append(t1_dir)\n",
    "                if len(hits) >= max_hits:\n",
    "                    return sorted(set(hits))\n",
    "    return sorted(set(hits))\n",
    "\n",
    "roots = [Path.cwd(), Path(\"/content\"), Path(\"/content/drive/MyDrive\")]\n",
    "found = _find_t1_roots(roots)\n",
    "\n",
    "print(\"Diagnostic search roots:\")\n",
    "for r in roots:\n",
    "    print(\" -\", r)\n",
    "\n",
    "if found:\n",
    "    print(\"\\nFound T1 folder candidates:\")\n",
    "    for p in found:\n",
    "        print(\" -\", p)\n",
    "    print(\"\\nIf needed, set this in Cell 4:\")\n",
    "    print(f\"DATASET_ROOT_OVERRIDE = r\\\"{found[0].parent}\\\"\")\n",
    "else:\n",
    "    print(\"\\nNo T1 folder found in this runtime.\")\n",
    "    print(\"Run the gdown download/extract setup in Cell 4, then rerun this diagnostic.\")"
   ]
  },
